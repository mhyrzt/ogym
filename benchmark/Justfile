# Configuration
rust_bin_path := "target/release/benchmark"
py_bench := "gym_benchmarks.py"
results_dir := "results"
warmup := env('HYPERPARAM_WARMUP', '3')
home_dir := env('HOME')

# Locate MuJoCo and select the host's dynamic-library search variable.
mujoco_dir := env('MUJOCO_DIR', home_dir / ".local/mujoco")
mujoco_lib_path := mujoco_dir / "lib"
loader_path_var := if os() == "linux" { "LD_LIBRARY_PATH" } else if os() == "macos" { "DYLD_LIBRARY_PATH" } else { error("MuJoCo benchmarks are unsupported on " + os()) }
mujoco_loader_env := loader_path_var + "=" + mujoco_lib_path + ":$" + loader_path_var

# Default recipe lists available commands.
default:
    @just --list

# Build the Rust benchmark binary in release mode.
build:
    cargo build --release

# Create the results directory.
prepare:
    mkdir -p {{ results_dir }}

# Clean benchmark build artifacts and results.
clean:
    cargo clean
    uv clean
    rm -rf {{ results_dir }}

# Compare one ogym environment with its Gymnasium equivalent.
[private]
_compare env label: build prepare
    @echo "Benchmarking {{ label }}..."
    hyperfine --warmup {{ warmup }} \
        --export-json "{{ results_dir }}/{{ env }}.json" \
        --command-name "ogym-{{ label }}" '{{ mujoco_loader_env }} {{ rust_bin_path }} {{ env }}' \
        --command-name "gym-{{ label }}" 'uv run {{ py_bench }} {{ env }}'

# Individual environment comparisons.
acrobot: (_compare "acrobot" "acrobot")
cartpole: (_compare "cartpole" "cartpole")
mountain-car: (_compare "mountain_car" "mountain-car")
pendulum: (_compare "pendulum" "pendulum")
blackjack: (_compare "blackjack" "blackjack")
cliff-walking: (_compare "cliff_walking" "cliff-walking")
frozen-lake: (_compare "frozen_lake" "frozen-lake")
taxi: (_compare "taxi" "taxi")
bipedal-walker: (_compare "bipedal_walker" "bipedal-walker")
lunar-lander: (_compare "lunar_lander" "lunar-lander")
ant: (_compare "ant" "ant")
half-cheetah: (_compare "half_cheetah" "half-cheetah")
hopper: (_compare "hopper" "hopper")
humanoid: (_compare "humanoid" "humanoid")
humanoid-standup: (_compare "humanoid_standup" "humanoid-standup")
inverted-double-pendulum: (_compare "inverted_double_pendulum" "inverted-double-pendulum")
inverted-pendulum: (_compare "inverted_pendulum" "inverted-pendulum")
pusher: (_compare "pusher" "pusher")
reacher: (_compare "reacher" "reacher")
swimmer: (_compare "swimmer" "swimmer")
walker2d: (_compare "walker2d" "walker2d")

# Run every comparison in one Hyperfine session.
all: build prepare
    #!/usr/bin/env bash
    set -euo pipefail

    environments=(
        "acrobot:acrobot"
        "cartpole:cartpole"
        "mountain-car:mountain_car"
        "pendulum:pendulum"
        "blackjack:blackjack"
        "cliff-walking:cliff_walking"
        "frozen-lake:frozen_lake"
        "taxi:taxi"
        "bipedal-walker:bipedal_walker"
        "lunar-lander:lunar_lander"
        "ant:ant"
        "half-cheetah:half_cheetah"
        "hopper:hopper"
        "humanoid:humanoid"
        "humanoid-standup:humanoid_standup"
        "inverted-double-pendulum:inverted_double_pendulum"
        "inverted-pendulum:inverted_pendulum"
        "pusher:pusher"
        "reacher:reacher"
        "swimmer:swimmer"
        "walker2d:walker2d"
    )

    hyperfine_args=(
        --show-output
        --warmup "{{ warmup }}"
        --export-json "{{ results_dir }}/all_results.json"
        --export-markdown "{{ results_dir }}/all_results.md"
    )

    for spec in "${environments[@]}"; do
        IFS=: read -r label env <<< "$spec"
        rust_command='{{ mujoco_loader_env }} {{ rust_bin_path }} '"$env"
        gym_command='uv run {{ py_bench }} '"$env"
        hyperfine_args+=(
            --command-name "ogym-$label" "$rust_command"
            --command-name "gym-$label" "$gym_command"
        )
    done

    hyperfine "${hyperfine_args[@]}"

# Generate plots from comprehensive results.
plot:
    uv run visualize.py

# Clean, benchmark, and plot.
full: clean all plot
    @echo "Full comparison complete. Check {{ results_dir }}/ for outputs."
