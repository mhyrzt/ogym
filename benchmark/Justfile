# Configuration
rust_bin_path := "target/release/benchmark"
py_bench_dir := "gym_benchmarks"
results_dir := "results"

# Dynamically get the User's Home directory
home_dir := env_var('HOME')

# Construct the MuJoCo path relative to Home
mujoco_lib_path := home_dir / ".local/mujoco/lib"

# Default recipe lists available commands
default:
    @just --list

# Build the Rust project in release mode
build:
    @echo "Building Rust project in release mode..."
    cargo build --release

# Create results directory
prepare:
    mkdir -p {{results_dir}}

# Clean build artifacts and results
clean:
    cargo clean
    uv clean
    rm -rf {{results_dir}}

# -----------------------------------------------------------------------------
# Individual Environment Comparisons
# -----------------------------------------------------------------------------

# Compare Acrobot performance
hyperfine-compare-acrobot: build prepare
    @echo "Benchmarking Acrobot..."
    hyperfine --warmup 3 \
        --export-json "{{results_dir}}/acrobot.json" \
        --command-name "ogym-acrobot" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} acrobot' \
        --command-name "gym-acrobot" 'uv run {{py_bench_dir}}/acrobot_gym.py'

# Compare CartPole performance
hyperfine-compare-cartpole: build prepare
    @echo "Benchmarking CartPole..."
    hyperfine --warmup 3 \
        --export-json "{{results_dir}}/cartpole.json" \
        --command-name "ogym-cartpole" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} cartpole' \
        --command-name "gym-cartpole" 'uv run {{py_bench_dir}}/cartpole_gym.py'

# Compare MountainCar performance
hyperfine-compare-mountain-car: build prepare
    @echo "Benchmarking MountainCar..."
    hyperfine --warmup 3 \
        --export-json "{{results_dir}}/mountain_car.json" \
        --command-name "ogym-mountain-car" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} mountain_car' \
        --command-name "gym-mountain-car" 'uv run {{py_bench_dir}}/mountain_car_gym.py'

# Compare Pendulum performance
hyperfine-compare-pendulum: build prepare
    @echo "Benchmarking Pendulum..."
    hyperfine --warmup 3 \
        --export-json "{{results_dir}}/pendulum.json" \
        --command-name "ogym-pendulum" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} pendulum' \
        --command-name "gym-pendulum" 'uv run {{py_bench_dir}}/pendulum_gym.py'

# -----------------------------------------------------------------------------
# Comprehensive Benchmarks
# -----------------------------------------------------------------------------

# Run a massive comparison of all environments in one Hyperfine session
hyperfine-compare-all: build prepare
    @echo "Running comprehensive benchmark suite..."
    hyperfine --warmup 3 \
        --export-json "{{results_dir}}/all_results.json" \
        --export-markdown "{{results_dir}}/all_results.md" \
        --command-name "ogym-acrobot"      'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} acrobot' \
        --command-name "gym-acrobot"       'uv run {{py_bench_dir}}/acrobot_gym.py' \
        --command-name "ogym-cartpole"     'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} cartpole' \
        --command-name "gym-cartpole"      'uv run {{py_bench_dir}}/cartpole_gym.py' \
        --command-name "ogym-mountain-car" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} mountain_car' \
        --command-name "gym-mountain-car"  'uv run {{py_bench_dir}}/mountain_car_gym.py' \
        --command-name "ogym-pendulum"     'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} pendulum' \
        --command-name "gym-pendulum"      'uv run {{py_bench_dir}}/pendulum_gym.py'

# -----------------------------------------------------------------------------
# Visualization & Full Workflow (As described in README)
# -----------------------------------------------------------------------------

# Generate plots from results (Requires visualize_results.py)
plot-results:
    @if [ -f "visualize_results.py" ]; then \
        echo "Generating visualizations..."; \
        uv run visualize_results.py; \
    else \
        echo "Warning: visualize_results.py not found. Skipping plotting."; \
    fi

# Run everything: Clean, Build, Benchmark, and Plot
full-comparison: clean hyperfine-compare-all plot-results
    @echo "Full comparison complete. Check {{results_dir}}/ for outputs."
