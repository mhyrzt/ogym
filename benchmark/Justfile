# -----------------------------------------------------------------------------
# Comprehensive Benchmarks
# -----------------------------------------------------------------------------

# Run a massive comparison of all environments in one Hyperfine session
all: build prepare
    @echo "Running comprehensive benchmark suite..."
    hyperfine --show-output --warmup 3 \
        --export-json "{{results_dir}}/all_results.json" \
        --export-markdown "{{results_dir}}/all_results.md" \
        --command-name "ogym-acrobot"      'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} acrobot' \
        --command-name "gym-acrobot"       'uv run {{py_bench_dir}}/acrobot_gym.py' \
        --command-name "ogym-cartpole"     'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} cartpole' \
        --command-name "gym-cartpole"      'uv run {{py_bench_dir}}/cartpole_gym.py' \
        --command-name "ogym-mountain-car" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} mountain_car' \
        --command-name "gym-mountain-car"  'uv run {{py_bench_dir}}/mountain_car_gym.py' \
        --command-name "ogym-pendulum"     'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} pendulum' \
        --command-name "gym-pendulum"      'uv run {{py_bench_dir}}/pendulum_gym.py' \
        --command-name "ogym-ant"          'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} ant' \
        --command-name "gym-ant"           'uv run {{py_bench_dir}}/ant_gym.py' \
        --command-name "ogym-half-cheetah" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} half_cheetah' \
        --command-name "gym-half-cheetah"  'uv run {{py_bench_dir}}/half_cheetah_gym.py' \
        --command-name "ogym-hopper"       'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} hopper' \
        --command-name "gym-hopper"        'uv run {{py_bench_dir}}/hopper_gym.py' \
        --command-name "ogym-humanoid"     'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} humanoid' \
        --command-name "gym-humanoid"      'uv run {{py_bench_dir}}/gym_benchmarks.py humanoid' \
        --command-name "ogym-humanoid-standup" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} humanoid_standup' \
        --command-name "gym-humanoid-standup" 'uv run {{py_bench_dir}}/gym_benchmarks.py humanoid_standup' \
        --command-name "ogym-inverted-double-pendulum" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} inverted_double_pendulum' \
        --command-name "gym-inverted-double-pendulum" 'uv run {{py_bench_dir}}/gym_benchmarks.py inverted_double_pendulum' \
        --command-name "ogym-inverted-pendulum" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} inverted_pendulum' \
        --command-name "gym-inverted-pendulum" 'uv run {{py_bench_dir}}/gym_benchmarks.py inverted_pendulum' \
        --command-name "ogym-pusher"       'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} pusher' \
        --command-name "gym-pusher"        'uv run {{py_bench_dir}}/gym_benchmarks.py pusher' \
        --command-name "ogym-reacher"      'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} reacher' \
        --command-name "gym-reacher"       'uv run {{py_bench_dir}}/gym_benchmarks.py reacher' \
