# -----------------------------------------------------------------------------
# Comprehensive Benchmarks
# -----------------------------------------------------------------------------

# Run a massive comparison of all environments in one Hyperfine session
all: build prepare
    @echo "Running comprehensive benchmark suite..."
    hyperfine --show-output --warmup {{warmup}}  \
        --export-json "{{results_dir}}/all_results.json" \
        --export-markdown "{{results_dir}}/all_results.md" \
        --command-name "ogym-acrobot"      'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} acrobot' \
        --command-name "gym-acrobot"       'uv run {{py_bench}} acrobot' \
        --command-name "ogym-cartpole"     'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} cartpole' \
        --command-name "gym-cartpole"      'uv run {{py_bench}} cartpole' \
        --command-name "ogym-mountain-car" 'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} mountain_car' \
        --command-name "gym-mountain-car"  'uv run {{py_bench}} mountain_car' \
        --command-name "ogym-pendulum"     'DYLD_LIBRARY_PATH={{mujoco_lib_path}}:$DYLD_LIBRARY_PATH {{rust_bin_path}} pendulum' \
        --command-name "gym-pendulum"      'uv run {{py_bench}} pendulum' \
        --command-name "ogym-blackjack"    '{{rust_bin_path}} blackjack' \
        --command-name "gym-blackjack"     'uv run {{py_bench}} blackjack' \
        --command-name "ogym-cliff-walking" '{{rust_bin_path}} cliff_walking' \
        --command-name "gym-cliff-walking" 'uv run {{py_bench}} cliff_walking' \
        --command-name "ogym-frozen-lake"  '{{rust_bin_path}} frozen_lake' \
        --command-name "gym-frozen-lake"   'uv run {{py_bench}} frozen_lake' \
        --command-name "ogym-taxi"         '{{rust_bin_path}} taxi' \
        --command-name "gym-taxi"          'uv run {{py_bench}} taxi' \
        --command-name "ogym-bipedal-walker" '{{rust_bin_path}} bipedal_walker' \
